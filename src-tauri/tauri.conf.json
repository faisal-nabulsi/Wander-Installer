{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wander Installer",
  "version": "2.2.9",
  "identifier": "com.faisal-nabulsi.wander-installer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Wander Installer",
        "width": 800,
        "height": 600,
        "minHeight": 300,
        "minWidth": 400
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEzNTREOUU1QjFDMDRCNzgKUldSNFM4Q3g1ZGxVRTRvYjhDaW5RNURBMTZ0MnlSU3o5aWRvS0UvWGhJYnlpMzVDQmVtS3FvbVMK",
      "endpoints": [
        "https://github.com/faisal-nabulsi/Wander-Installer/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}